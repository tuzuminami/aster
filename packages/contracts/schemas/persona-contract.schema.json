{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aster.dev/schemas/persona-contract.schema.json",
  "type": "object",
  "required": ["schemaVersion", "persona", "components", "policyReferences"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "persona": {
      "type": "object",
      "required": ["displayName", "purpose", "voice"],
      "additionalProperties": false,
      "properties": {
        "displayName": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "voice": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "body"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["instruction", "boundary", "context"] },
          "body": { "type": "string", "minLength": 1 },
          "dependsOn": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "policyReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version", "required"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "capability"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "capability": { "enum": ["context_injector", "renderer"] }
        }
      }
    }
  }
}
