{
  "name": "@aster/persona-contract-compiler",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/packages/core/src/index.js",
  "types": "./dist/packages/core/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/core/src/index.d.ts",
      "default": "./dist/packages/core/src/index.js"
    },
    "./contracts/*": "./packages/contracts/*"
  },
  "files": [
    "dist/packages",
    "dist/apps",
    "packages/contracts",
    "db/migrations",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.ts",
    "test:compiled": "pnpm run build && node --test dist/tests/*.test.js",
    "check:private-boundary": "node scripts/check-private-boundary.mjs",
    "lint": "pnpm run check:private-boundary && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3"
  }
}
